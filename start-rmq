#!/bin/bash

CONTAINER_NAME="rabbitmq-ids"

# Check if a container with this name already exists (running or stopped)
EXISTING=$(docker ps -aq --filter "name=^${CONTAINER_NAME}$")

if [ -n "$EXISTING" ]; then
    STATUS=$(docker inspect -f '{{.State.Status}}' $CONTAINER_NAME)
    if [ "$STATUS" = "running" ]; then
        echo "[!] Une instance RabbitMQ est déjà en cours d'exécution (conteneur: $CONTAINER_NAME)."
        echo "    Utilisez ./stop-rmq pour l'arrêter d'abord."
        exit 1
    else
        echo "[*] Suppression du conteneur arrêté existant..."
        docker rm $CONTAINER_NAME
    fi
fi

echo "[*] Démarrage de RabbitMQ..."
docker run -d \
    --name $CONTAINER_NAME \
    -p 5672:5672 \
    -p 15672:15672 \
    rabbitmq:3-management

echo "[*] Attente du démarrage de RabbitMQ..."
TIMEOUT=60
ELAPSED=0
until (echo > /dev/tcp/localhost/5672) 2>/dev/null; do
    sleep 2
    ELAPSED=$((ELAPSED + 2))
    if [ $ELAPSED -ge $TIMEOUT ]; then
        echo "[!] Timeout : RabbitMQ n'a pas démarré après ${TIMEOUT}s."
        echo "    Logs du conteneur :"
        docker logs --tail 20 $CONTAINER_NAME
        exit 1
    fi
done

echo "[+] RabbitMQ prêt. Interface de gestion : http://localhost:15672 (guest/guest)"
